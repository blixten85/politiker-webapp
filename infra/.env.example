# politiker-webapp — konfiguration för infra/setup.sh
# Kopieras automatiskt till ~/.claude/credentials.env vid första körningen.
# Fyll i värdena och kör `bash infra/setup.sh` igen. Tomma valfria fält hoppas över.

# ── Egen domän ──────────────────────────────────────────────────────────────
# Domän för app-Workern (måste finnas som zon i ditt Cloudflare-konto).
# Lämna TOM för att deploya till <worker>.workers.dev istället.
CUSTOM_DOMAIN=

# ── Krypteringsnyckel ───────────────────────────────────────────────────────
# AES-nyckel för krypterade SMTP-lösenord. Lämna TOM — genereras automatiskt
# vid första körningen (openssl rand -base64 32) och skrivs tillbaka hit.
MAIL_CRED_KEY=

# ── Systemmail (obligatoriskt) ──────────────────────────────────────────────
# SMTP-konto som skickar verifieringskoder och feedback-notiser.
# Värden för host/user/from sätts i app/wrangler.jsonc -> "vars".
SYSTEM_SMTP_PASSWORD=

# ── Feedback / felrapportering (rekommenderas) ──────────────────────────────
# Fine-grained GitHub-PAT med Issues:Write på ditt fork-repo.
GITHUB_FEEDBACK_TOKEN=

# ── Autonom kampanj-Worker (valfritt) ───────────────────────────────────────
# Lämna alla tre tomma för att hoppa över campaign-Workern helt.
ANTHROPIC_API_KEY=
# Gmail-konto för utgående kampanjmail och IMAP bounce-läsning.
# Skapa app-lösenord på: myaccount.google.com/apppasswords
GMAIL_EMAIL=
GMAIL_PASSWORD=

# ── OAuth-inloggning (valfritt) ─────────────────────────────────────────────
# Lämna tomt för enbart e-post+lösenord. Client-ID:n sätts i app/wrangler.jsonc.
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_SECRET=

# ── Felspårning (valfritt) ─────────────────────────────────────────────────
# Sätts som en Worker-secret i app, sender och campaign.
SENTRY_DSN=

# ── Lokala infra-skript (valfritt) ──────────────────────────────────────────
# Cloudflare API-token (D1-skriv) som cf-api.sh använder. Behövs inte av setup.sh.
CLOUDFLARE_API_TOKEN_POLITIKER=
