# Cloudflare API-token med D1-skrivrättigheter till politiker_webapp-databasen
CLOUDFLARE_API_TOKEN_POLITIKER=

# Anthropic API-nyckel (används av lokala infra-skript)
ANTHROPIC_API_KEY=

# Gmail-konto för utgående kampanjmail och IMAP bounce-läsning
# Skapa app-lösenord på: myaccount.google.com/apppasswords
GMAIL_EMAIL=
GMAIL_PASSWORD=

# Outlook-konto (används ej längre, ersatt av Gmail)
# OUTLOOK_EMAIL=
# OUTLOOK_PASSWORD=
