# @sentry/cloudflare deklarerar en peer-dependency på
# @cloudflare/workers-types@^4.x, men wrangler kräver efterhand nyare
# workers-types-versioner (verifierat kompatibelt i praktiken — tsc/wrangler
# dry-run går igenom felfritt oavsett vilken sida som ligger steget före).
# Utan denna rad stoppar CI:s `npm ci` hårt på ERESOLVE varje gång Dependabot
# bumpar endera paketet innan det andra hunnit ikapp.
legacy-peer-deps=true
