{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:weekly",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":rebaseStalePrs"
  ],
  "timezone": "Europe/Stockholm",
  "labels": ["dependencies", "renovate"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": { "enabled": true, "schedule": ["after 5am and before 5:30am on sunday"] },
  "vulnerabilityAlerts": { "enabled": true, "labels": ["security"] },
  "packageRules": [
    { "description": "Automerge patch updates on their own (kept out of any non-major group)", "matchUpdateTypes": ["patch"], "automerge": true },
    { "matchDepTypes": ["devDependencies"], "groupName": "dev-dependencies", "automerge": true },
    { "description": "Group GitHub Actions updates", "matchManagers": ["github-actions"], "groupName": "github-actions" },
    { "description": "wrangler (senaste 4.107.0 inkluderat) kräver @cloudflare/workers-types ^4.x som peer dependency — håll tillbaka major-uppdateringar tills wrangler själv stöder v5", "matchPackageNames": ["@cloudflare/workers-types"], "allowedVersions": "<5.0.0" }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "schedule": [
    "after 5am and before 5:30am on sunday"
  ]
}